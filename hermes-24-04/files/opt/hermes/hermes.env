# Hermes Agent 1-Click notes
#
# Hermes user:  hermes
# Hermes home:  /home/hermes/.hermes
# Workspace:    /home/hermes/workspace
#
# Configure providers with:
#   sudo -u hermes -H /home/hermes/.local/bin/hermes setup
# or:
#   hermes setup
#
# Provider keys are stored in /home/hermes/.hermes/.env by Hermes itself.
#
# DigitalOcean Gradient preconfiguration (optional):
#   GRADIENT_KEY    Gradient model access key (Gen AI / Gradient in the control panel)
#   GRADIENT_MODEL  Inference model id, e.g. minimax-m2.5, kimi-k2.5, glm-5
#
# On first boot, /opt/hermes/apply-gradient-from-env.sh reads /etc/environment
# first, then this file. If GRADIENT_KEY is set, it configures Hermes for
# DigitalOcean Gradient and skips the interactive first-login setup wizard.
GRADIENT_KEY=
GRADIENT_MODEL=minimax-m2.5
