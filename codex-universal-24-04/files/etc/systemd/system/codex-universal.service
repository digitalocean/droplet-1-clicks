[Unit]
Description=Codex Universal Development Environment
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/codex-universal
TimeoutStartSec=900
ExecStart=/usr/bin/docker compose -f /opt/codex-universal/docker-compose.yml up -d --wait
ExecStop=/usr/bin/docker compose -f /opt/codex-universal/docker-compose.yml down
ExecReload=/usr/bin/docker compose -f /opt/codex-universal/docker-compose.yml restart

[Install]
WantedBy=multi-user.target
