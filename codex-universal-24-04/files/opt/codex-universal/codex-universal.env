# Codex Universal environment configuration
#
# Edit language runtime versions here, then restart:
#   /opt/codex-universal/restart-codex-universal.sh
#
# See supported versions:
#   https://github.com/openai/codex-universal#configuring-language-runtimes

# Upstream image tag pulled during build and first boot
IMAGE=ghcr.io/openai/codex-universal:latest
TAG=latest

CODEX_ENV_PYTHON_VERSION=3.12
CODEX_ENV_NODE_VERSION=20
CODEX_ENV_RUST_VERSION=1.87.0
CODEX_ENV_GO_VERSION=1.23.8
CODEX_ENV_SWIFT_VERSION=6.2
CODEX_ENV_RUBY_VERSION=3.4.4
CODEX_ENV_PHP_VERSION=8.4
CODEX_ENV_JAVA_VERSION=21
