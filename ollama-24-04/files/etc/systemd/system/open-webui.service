[Unit]
Description=Open Web UI Service
After=network.target

[Service]
User=digitalocean
WorkingDirectory=/home/digitalocean
Environment=PATH=/home/digitalocean/anaconda3/envs/ui/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/home/digitalocean/anaconda3/envs/ui/bin/open-webui serve
Restart=always
SyslogIdentifier=open-webui
StandardOutput=append:/var/log/open-webui.log
StandardError=append:/var/log/open-webui.log

[Install]
WantedBy=multi-user.target
