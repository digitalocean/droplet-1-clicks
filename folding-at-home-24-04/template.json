{
  "variables": {
    "token": "{{env `DIGITALOCEAN_TOKEN`}}",
    "image_name": "folding-at-home-{{timestamp}}",
    "apt_packages": ""
  },
  "builders": [
    {
      "type": "digitalocean",
      "api_token": "{{user `token`}}",
      "image": "ubuntu-24-04-x64",
      "region": "nyc3",
      "size": "s-1vcpu-1gb",
      "ssh_username": "root",
      "snapshot_name": "{{user `image_name`}}"
    }
  ],
  "provisioners": [
    {
      "type": "file",
      "source": "folding-at-home-24-04/files/etc/",
      "destination": "/etc/"
    },
    {
      "type": "file",
      "source": "folding-at-home-24-04/files/var/",
      "destination": "/var/"
    },
    {
      "type": "file",
      "source": "common/files/var/",
      "destination": "/var/"
    },
    {
      "type": "shell",
      "inline": [
        "cloud-init status --wait",
        "apt -qqy update",
        "apt -qqy -o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold' full-upgrade",
        "apt -qqy -o Dpkg::Options::='--force-confdef' -o Dpkg::Options::='--force-confold' install {{user `apt_packages`}}"
      ]
    },
    {
      "type": "shell",
      "inline": [
        "export USER=Anonymous",
        "export TEAM=0",
        "export PASSKEY=",
        "export POWER=medium",
        "export AUTOSTART=true",
        "echo \"fahclient fahclient/autostart boolean $AUTOSTART\" | sudo debconf-set-selections",
        "echo \"fahclient fahclient/power select $POWER\" | sudo debconf-set-selections",
        "echo \"fahclient fahclient/team string $TEAM\" | sudo debconf-set-selections",
        "echo \"fahclient fahclient/passkey string $PASSKEY\" | sudo debconf-set-selections",
        "echo \"fahclient fahclient/user string $USER\" | sudo debconf-set-selections",
        "wget https://download.foldingathome.org/releases/public/fah-client/debian-10-64bit/release/fah-client_8.5.5_amd64.deb",
        "dpkg -i --force-depends fah-client_8.5.5_amd64.deb",
        "rm fah-client_8.5.5_amd64.deb"
      ]
    },
    {
      "type": "shell",
      "scripts": [        
        "common/scripts/018-force-ssh-logout.sh",
        "common/scripts/020-application-tag.sh",
        "common/scripts/900-cleanup.sh"
      ]
    }
  ]
}
